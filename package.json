{
  "name": "whmcs-emoji-compatibility-guide",
  "version": "2.4.25",
  "description": "A searchable, conservative emoji shortlist for testing in WHMCS product names, email templates, and knowledge base articles. No dependencies.",
  "type": "module",
  "private": true,
  "keywords": [
    "whmcs",
    "emoji",
    "compatibility",
    "unicode",
    "reference"
  ],
  "scripts": {
    "check": "node --check docs/search.js && node --check docs/app.js && node --check scripts/export-csv.mjs",
    "export:csv": "node scripts/export-csv.mjs",
    "test": "node --test test/search.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test test/search.test.mjs",
    "serve": "python3 -m http.server 8441 -d docs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "docs/data/emoji.csv",
    "docs/data/emoji.json",
    "docs/search.js",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "author": "Jayden Yoon ZK",
  "homepage": "https://jaydenyoonzk.github.io/whmcs-emoji-compatibility-guide/",
  "bugs": "https://github.com/JaydenYoonZK/whmcs-emoji-compatibility-guide/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaydenYoonZK/whmcs-emoji-compatibility-guide.git"
  }
}
